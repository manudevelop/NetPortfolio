@page "/projects"
@inject IPortfolioDataService DataService

<PageTitle>Projects | Manuel David</PageTitle>

<div class="projects-page">
    <section class="projects-hero container">
        <div class="section-header">
            <span class="section-label">02</span>
            <h1 class="section-title">Proyectos</h1>
        </div>
        <p class="section-description">
            Proyectos destacados que demuestran mi experiencia en arquitecturas distribuidas y desarrollo .NET
        </p>
    </section>
    
    <section class="projects-filters container">
        <button class="filter-btn @(_selectedFilter is null ? "active" : "")" 
                @onclick="() => _selectedFilter = null">
            <span class="filter-dot"></span>
            Todos
        </button>
        @foreach (var tech in _allTechs)
        {
            <button class="filter-btn @(_selectedFilter == tech ? "active" : "")" 
                    @onclick="() => _selectedFilter = tech">
                <span class="filter-dot"></span>
                @tech
            </button>
        }
    </section>
    
    <section class="projects-grid container">
        @foreach (var project in _filteredProjects)
        {
            <article class="project-card @((project.IsFeatured) ? "featured" : "")">
                <div class="card-inner">
                    <div class="card-header">
                        @if (project.IsFeatured)
                        {
                            <span class="featured-badge">Featured</span>
                        }
                        <div class="card-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                            </svg>
                        </div>
                    </div>
                    
                    <div class="card-content">
                        <h3 class="card-title">@project.Title</h3>
                        <p class="card-description">@project.Description</p>
                        
                        <div class="card-techs">
                            @foreach (var tech in project.Technologies.Take(4))
                            {
                                <span class="tech-tag">@tech</span>
                            }
                            @if (project.Technologies.Length > 4)
                            {
                                <span class="tech-more">+@(project.Technologies.Length - 4)</span>
                            }
                        </div>
                    </div>
                    
                    <div class="card-footer">
                        @if (!string.IsNullOrEmpty(project.GithubUrl))
                        {
                            <a href="@project.GithubUrl" target="_blank" class="card-link">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                </svg>
                                <span>Code</span>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(project.DemoUrl))
                        {
                            <a href="@project.DemoUrl" target="_blank" class="card-link">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                    <polyline points="15 3 21 3 21 9"/>
                                    <line x1="10" y1="14" x2="21" y2="3"/>
                                </svg>
                                <span>Demo</span>
                            </a>
                        }
                    </div>
                </div>
                
                <div class="card-glow"></div>
            </article>
        }
    </section>
</div>

@code {
    private PortfolioData? _data;
    private string? _selectedFilter;
    private IEnumerable<string> _allTechs = Array.Empty<string>();
    private IEnumerable<Project> _filteredProjects = Array.Empty<Project>();

    protected override async Task OnInitializedAsync()
    {
        _data = await DataService.GetDataAsync();
        UpdateProjects();
    }

    private void UpdateProjects()
    {
        if (_data?.Projects is { } projects)
        {
            _allTechs = projects
                .SelectMany(p => p.Technologies)
                .Distinct()
                .OrderBy(t => t)
                .ToArray();

            _filteredProjects = _selectedFilter is null
                ? projects
                : projects.Where(p => p.Technologies.Contains(_selectedFilter));
        }
    }
}

<style>
    .projects-page {
        padding: var(--spacing-3xl) 0;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: var(--spacing-lg);
        margin-bottom: var(--spacing-md);
    }

    .section-label {
        font-family: var(--font-display);
        font-size: 0.875rem;
        color: var(--color-accent);
        padding: var(--spacing-sm) var(--spacing-md);
        background: rgba(34, 211, 238, 0.1);
        border: 1px solid rgba(34, 211, 238, 0.2);
        border-radius: var(--radius-md);
    }

    .section-title {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        color: var(--color-text);
    }

    .section-description {
        color: var(--color-text-muted);
        font-size: 1.0625rem;
        max-width: 600px;
        margin-bottom: var(--spacing-2xl);
    }

    .projects-filters {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-2xl);
    }

    .filter-btn {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-md);
        background: transparent;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-full);
        color: var(--color-text-secondary);
        font-family: var(--font-display);
        font-size: 0.8125rem;
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .filter-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-text);
    }

    .filter-btn.active {
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: var(--color-bg);
    }

    .filter-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        opacity: 0;
        transition: opacity var(--transition-fast);
    }

    .filter-btn.active .filter-dot {
        opacity: 1;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: var(--spacing-lg);
    }

    .project-card {
        position: relative;
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .card-inner {
        position: relative;
        height: 100%;
        padding: var(--spacing-xl);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        display: flex;
        flex-direction: column;
        transition: all var(--transition-base);
        z-index: 1;
    }

    .project-card:hover .card-inner {
        border-color: var(--color-accent);
        transform: translateY(-4px);
    }

    .card-glow {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(34, 211, 238, 0.1), transparent);
        opacity: 0;
        transition: opacity var(--transition-base);
        pointer-events: none;
    }

    .project-card:hover .card-glow {
        opacity: 1;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: var(--spacing-lg);
    }

    .featured-badge {
        padding: var(--spacing-xs) var(--spacing-sm);
        background: rgba(34, 211, 238, 0.15);
        color: var(--color-accent);
        font-family: var(--font-display);
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: var(--radius-sm);
    }

    .card-icon {
        color: var(--color-text-muted);
        opacity: 0.5;
    }

    .card-content {
        flex: 1;
    }

    .card-title {
        font-size: 1.25rem;
        color: var(--color-text);
        margin-bottom: var(--spacing-sm);
    }

    .card-description {
        font-size: 0.9375rem;
        color: var(--color-text-secondary);
        line-height: 1.6;
        margin-bottom: var(--spacing-lg);
    }

    .card-techs {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-xs);
        margin-bottom: var(--spacing-lg);
    }

    .tech-tag {
        padding: var(--spacing-xs) var(--spacing-sm);
        background: var(--color-bg);
        color: var(--color-text-muted);
        font-family: var(--font-display);
        font-size: 0.6875rem;
        border-radius: var(--radius-sm);
        border: 1px solid var(--color-border);
    }

    .tech-more {
        padding: var(--spacing-xs) var(--spacing-sm);
        background: transparent;
        color: var(--color-accent);
        font-family: var(--font-display);
        font-size: 0.6875rem;
    }

    .card-footer {
        display: flex;
        gap: var(--spacing-md);
        padding-top: var(--spacing-md);
        border-top: 1px solid var(--color-border);
    }

    .card-link {
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
        color: var(--color-text-secondary);
        font-family: var(--font-display);
        font-size: 0.8125rem;
        transition: color var(--transition-fast);
    }

    .card-link:hover {
        color: var(--color-accent);
    }
</style>